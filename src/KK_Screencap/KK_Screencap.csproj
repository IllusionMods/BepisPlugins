<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net35</TargetFramework>
		<OutputType>Library</OutputType>
		<RootNamespace>Screencap</RootNamespace>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<AssemblyName>Screencap</AssemblyName>
		<!-- NuGet packaging properties -->
		<PackageId>ScreenshotManager.Koikatu</PackageId>
		<PackageVersion>$(Version)</PackageVersion>
		<PackageDescription>Utility for capturing screenshots</PackageDescription>
		<PackageProjectUrl>https://gitgoon.dev/IllusionMods/BepisPlugins</PackageProjectUrl>
		<PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
		<PackageCopyright>$(Copyright)</PackageCopyright>
		<Company>IllusionMods</Company>
		<RepositoryUrl>https://gitgoon.dev/IllusionMods/BepisPlugins</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="IllusionLibs.BepInEx" Version="5.4.22" />
		<PackageReference Include="IllusionLibs.Koikatu.Assembly-CSharp" Version="2019.4.27.4" />
		<PackageReference Include="IllusionLibs.Koikatu.Assembly-CSharp-firstpass" Version="2019.4.27.4" />
		<PackageReference Include="IllusionLibs.Koikatu.Sirenix.Serialization" Version="2019.4.27.4" />
		<PackageReference Include="IllusionLibs.Koikatu.UnityEngine" Version="5.6.2.4" />
		<PackageReference Include="IllusionLibs.Koikatu.UnityEngine.UI" Version="5.6.2.4" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="PostProcessingRuntime">
			<HintPath>..\..\lib\PostProcessingRuntime.dll</HintPath>
			<Private>False</Private>
		</Reference>
	</ItemGroup>

	<Import Project="..\Shared\Shared.projitems" Label="Shared" />
	<Import Project="..\Core_Screencap\Core_Screencap.projitems" Label="Shared" />
	<Import Project="..\Core_Screencap_KKEC\Core_Screencap.projitems" Label="Shared" />
</Project>