		<PackageReference Include="IllusionLibs.Koikatu.UnityEngine.UI" Version="5.6.2.4" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="PostProcessingRuntime">
			<HintPath>..\..\lib\PostProcessingRuntime.dll</HintPath>
			<Private>False</Private>
		</Reference>
	</ItemGroup>

	<Import Project="..\Shared\Shared.projitems" Label="Shared" />
	<Import Project="..\Core_Screencap\Core_Screencap.projitems" Label="Shared" />
	<Import Project="..\Core_Screencap_KKEC\Core_Screencap.projitems" Label="Shared" />
