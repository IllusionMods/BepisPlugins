<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net35</TargetFramework>
		<OutputType>Library</OutputType>
		<RootNamespace>ExtensibleSaveFormat</RootNamespace>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<!-- NuGet packaging properties -->
		<PackageId>ExtensibleSaveFormat.PlayHome</PackageId>
		<PackageVersion>$(Version)</PackageVersion>
		<PackageDescription>Allows additional data to be saved to character, coordinate and scene cards</PackageDescription>
		<PackageProjectUrl>https://gitgoon.dev/IllusionMods/BepisPlugins</PackageProjectUrl>
		<PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
		<PackageCopyright>$(Copyright)</PackageCopyright>
		<Company>IllusionMods</Company>
		<RepositoryUrl>https://gitgoon.dev/IllusionMods/BepisPlugins</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="IllusionLibs.BepInEx" Version="5.4.22" />
		<PackageReference Include="IllusionLibs.PlayHome.Assembly-CSharp" Version="2018.3.11.4" />
		<PackageReference Include="IllusionLibs.PlayHome.Assembly-CSharp-firstpass" Version="2018.3.11.4" />
		<PackageReference Include="IllusionLibs.PlayHome.UnityEngine" Version="5.5.5.4" />
	</ItemGroup>

	<Import Project="..\Shared\Shared.projitems" Label="Shared" />
	<Import Project="..\Core_ExtensibleSaveFormat_Studio\Core_ExtensibleSaveFormat_Studio.projitems" Label="Shared" />
</Project>